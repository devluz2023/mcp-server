{
    "version": "0.2.0",
    "configurations": [
 
        {
            "name": "Debug Application",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/mp-gemini/venv/bin/python",
            "program": "${workspaceFolder}/mp-gemini/app.py", // ADICIONE O CAMINHO DO SEU ARQUIVO PRINCIPAL
            "cwd": "${workspaceFolder}/mp-gemini",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/mp-gemini" // AJUSTADO PARA ENXERGAR A PASTA SRC
                },
            "justMyCode": true
        },
        {
            "name": "Debug Streamlit (Server1)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "run",
                "app.py",
                "--server.port",
                "8501"
            ],
            "cwd": "${workspaceFolder}/mp-gemini",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": true
        },
        {
            "name": "Debug Docker (logistica-sku-analytics)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "127.0.0.1",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/server2",
                    "remoteRoot": "/app"
                }
            ]
        }
    ]
}