{
  "display_name": "Drift Metrics (PSI & KS)",
  "datasets": [
    {
      "name": "drift_metrics",
      "displayName": "Drift Metrics (PSI & KS)",
      "queryLines": [
        "WITH dates AS (\n",
        "  SELECT\n",
        "    explode(sequence(DATE '2025-01-01', DATE '2026-04-01', INTERVAL 1 MONTH)) AS reference_date\n",
        "),\n",
        "features AS (\n",
        "  SELECT\n",
        "    col AS feature\n",
        "  FROM\n",
        "    VALUES ('income'), ('age'), ('credit_score'), ('debt_ratio'), ('employment_years') AS t(col)\n",
        "),\n",
        "base AS (\n",
        "  SELECT\n",
        "    d.reference_date,\n",
        "    f.feature,\n",
        "    ABS(HASH(CONCAT(CAST(d.reference_date AS STRING), f.feature))) % 1000 / 1000.0 AS noise1,\n",
        "    ABS(HASH(CONCAT(CAST(d.reference_date AS STRING), f.feature, 'ks'))) % 1000 / 1000.0 AS noise2\n",
        "  FROM\n",
        "    dates d CROSS JOIN features f\n",
        ")\n",
        "SELECT\n",
        "  reference_date,\n",
        "  feature,\n",
        "  ROUND(\n",
        "    CASE\n",
        "      WHEN feature = 'income' THEN 0.02 + (MONTH(reference_date) * 0.012) + noise1 * 0.05\n",
        "      WHEN feature = 'age' THEN 0.01 + noise1 * 0.04\n",
        "      WHEN feature = 'credit_score' THEN 0.03 + (MONTH(reference_date) * 0.015) + noise1 * 0.06\n",
        "      WHEN\n",
        "        feature = 'debt_ratio'\n",
        "      THEN\n",
        "        0.05 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.2 + noise1 * 0.04\n",
        "      WHEN feature = 'employment_years' THEN 0.015 + noise1 * 0.03\n",
        "    END,\n",
        "    4\n",
        "  ) AS psi_value,\n",
        "  ROUND(\n",
        "    CASE\n",
        "      WHEN feature = 'income' THEN 0.03 + (MONTH(reference_date) * 0.008) + noise2 * 0.04\n",
        "      WHEN feature = 'age' THEN 0.02 + noise2 * 0.03\n",
        "      WHEN feature = 'credit_score' THEN 0.04 + (MONTH(reference_date) * 0.01) + noise2 * 0.05\n",
        "      WHEN\n",
        "        feature = 'debt_ratio'\n",
        "      THEN\n",
        "        0.06 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.15 + noise2 * 0.03\n",
        "      WHEN feature = 'employment_years' THEN 0.02 + noise2 * 0.025\n",
        "    END,\n",
        "    4\n",
        "  ) AS ks_statistic,\n",
        "  CASE\n",
        "    WHEN\n",
        "      ROUND(\n",
        "        CASE\n",
        "          WHEN feature = 'income' THEN 0.02 + (MONTH(reference_date) * 0.012) + noise1 * 0.05\n",
        "          WHEN feature = 'age' THEN 0.01 + noise1 * 0.04\n",
        "          WHEN feature = 'credit_score' THEN 0.03 + (MONTH(reference_date) * 0.015) + noise1 * 0.06\n",
        "          WHEN\n",
        "            feature = 'debt_ratio'\n",
        "          THEN\n",
        "            0.05 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.2 + noise1 * 0.04\n",
        "          WHEN feature = 'employment_years' THEN 0.015 + noise1 * 0.03\n",
        "        END,\n",
        "        4\n",
        "      ) >= 0.25\n",
        "    THEN\n",
        "      'Alto'\n",
        "    WHEN\n",
        "      ROUND(\n",
        "        CASE\n",
        "          WHEN feature = 'income' THEN 0.02 + (MONTH(reference_date) * 0.012) + noise1 * 0.05\n",
        "          WHEN feature = 'age' THEN 0.01 + noise1 * 0.04\n",
        "          WHEN feature = 'credit_score' THEN 0.03 + (MONTH(reference_date) * 0.015) + noise1 * 0.06\n",
        "          WHEN\n",
        "            feature = 'debt_ratio'\n",
        "          THEN\n",
        "            0.05 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.2 + noise1 * 0.04\n",
        "          WHEN feature = 'employment_years' THEN 0.015 + noise1 * 0.03\n",
        "        END,\n",
        "        4\n",
        "      ) >= 0.1\n",
        "    THEN\n",
        "      'Moderado'\n",
        "    ELSE 'Estável'\n",
        "  END AS psi_status,\n",
        "  CASE\n",
        "    WHEN\n",
        "      ROUND(\n",
        "        CASE\n",
        "          WHEN feature = 'income' THEN 0.03 + (MONTH(reference_date) * 0.008) + noise2 * 0.04\n",
        "          WHEN feature = 'age' THEN 0.02 + noise2 * 0.03\n",
        "          WHEN feature = 'credit_score' THEN 0.04 + (MONTH(reference_date) * 0.01) + noise2 * 0.05\n",
        "          WHEN\n",
        "            feature = 'debt_ratio'\n",
        "          THEN\n",
        "            0.06 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.15 + noise2 * 0.03\n",
        "          WHEN feature = 'employment_years' THEN 0.02 + noise2 * 0.025\n",
        "        END,\n",
        "        4\n",
        "      ) >= 0.15\n",
        "    THEN\n",
        "      'Drift Detectado'\n",
        "    WHEN\n",
        "      ROUND(\n",
        "        CASE\n",
        "          WHEN feature = 'income' THEN 0.03 + (MONTH(reference_date) * 0.008) + noise2 * 0.04\n",
        "          WHEN feature = 'age' THEN 0.02 + noise2 * 0.03\n",
        "          WHEN feature = 'credit_score' THEN 0.04 + (MONTH(reference_date) * 0.01) + noise2 * 0.05\n",
        "          WHEN\n",
        "            feature = 'debt_ratio'\n",
        "          THEN\n",
        "            0.06 + (DATEDIFF(reference_date, DATE '2025-01-01') / 365.0) * 0.15 + noise2 * 0.03\n",
        "          WHEN feature = 'employment_years' THEN 0.02 + noise2 * 0.025\n",
        "        END,\n",
        "        4\n",
        "      ) >= 0.08\n",
        "    THEN\n",
        "      'Alerta'\n",
        "    ELSE 'Normal'\n",
        "  END AS ks_status\n",
        "FROM\n",
        "  base\n",
        "ORDER BY\n",
        "  reference_date,\n",
        "  feature"
      ]
    }
  ],
